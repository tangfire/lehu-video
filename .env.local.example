# Copy this file to .env.local for local development.
# This file is intentionally low-risk and should not be used in production.

MYSQL_ROOT_PASSWORD=8888.216
REDIS_PASSWORD=8888.216

LEHU_MYSQL_DSN=root:8888.216@tcp(mysql:3306)/lehu_campus_db?parseTime=True&loc=Local
LEHU_REDIS_ADDR=redis:6379
